# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/studypilot"

# ── Auth (NextAuth v5) ────────────────────────────────────
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_API_URL="/api"
BACKEND_URL="http://localhost:4000"

# ── AI ────────────────────────────────────────────────────
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"          # fast tier for tutoring/quiz gen
GEMINI_SAFETY_LEVEL="BLOCK_LOW_AND_ABOVE" # maximum safety filtering

# ── Cache / Rate limiting ─────────────────────────────────
REDIS_URL="redis://localhost:6379"
RATE_LIMIT_PROMPTS_PER_DAY="100"

# ── Storage ───────────────────────────────────────────────
GCS_BUCKET_NAME="studypilot-uploads"
GOOGLE_APPLICATION_CREDENTIALS="./gcp-service-account.json"

# ── Data privacy ──────────────────────────────────────────
ANSWER_RETENTION_DAYS="30"
REQUIRE_PARENT_CONSENT_UNDER_AGE="13"

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
