# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/studypilot"

# ── Redis (rate limiting + Gemini response caching) ───────
REDIS_URL="redis://localhost:6379"

# ── JWT auth ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET="replace-with-a-random-32+-char-secret"
JWT_REFRESH_SECRET="replace-with-a-different-random-32+-char-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS="30"

# ── Google Gemini ───────────────────────────────────────────
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# ── Google OAuth (optional — Google login disables gracefully if unset) ──
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Data privacy (GDPR-aligned) ────────────────────────────
ANSWER_RETENTION_DAYS="30"

# ── Rate limiting ───────────────────────────────────────────
RATE_LIMIT_PROMPTS_PER_DAY="100"

# ── CORS — set to your frontend's real origin in production ─
CORS_ORIGIN="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"

# ── App ───────────────────────────────────────────────────
PORT="4000"
NODE_ENV="development"

# ── Paystack (payment integration) ────────────────────────
# Get your secret key from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=""
