{
  "name": "studypilot-ai-backend",
  "version": "0.1.0",
  "private": true,
  "description": "StudyPilot AI — Node.js/Express backend with Prisma, Gemini AI, Redis, and JWT auth",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:raw": "set -a && . ./.env && set +a && psql \"$DATABASE_URL\" -f prisma/migrations/0001_init/migration.sql",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "job:purge-old-answers": "tsx src/jobs/purgeOldAnswers.ts"
  },
  "overrides": {
    "path-to-regexp": "0.1.13"
  },
  "dependencies": {
    "@google/generative-ai": "0.21.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "2.4.3",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.22.2",
    "express-rate-limit": "7.5.0",
    "helmet": "8.0.0",
    "ioredis": "5.4.1",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.11.0",
    "multer": "2.2.0",
    "node-cron": "4.2.1",
    "passport": "0.7.0",
    "passport-google-oauth20": "2.0.0",
    "pg": "8.13.1",
    "prisma": "^6.19.3",
    "rate-limit-redis": "4.2.0",
    "sanitize-html": "2.14.0",
    "uuid": "11.1.1",
    "winston": "3.17.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.8",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.25",
    "@types/ioredis-mock": "^8.2.7",
    "@types/jsonwebtoken": "9.0.7",
    "@types/morgan": "1.9.9",
    "@types/multer": "1.4.12",
    "@types/node": "22.10.2",
    "@types/passport": "1.0.17",
    "@types/passport-google-oauth20": "2.0.16",
    "@types/pg": "8.11.10",
    "@types/sanitize-html": "2.13.0",
    "@types/supertest": "6.0.2",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.18.1",
    "@typescript-eslint/parser": "8.18.1",
    "eslint": "^9.39.4",
    "ioredis-mock": "^8.13.1",
    "supertest": "7.0.0",
    "tsx": "^4.22.4",
    "typescript": "5.7.2",
    "vitest": "^4.1.9",
    "vitest-mock-extended": "2.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
